rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Expenses
    match /users/{userId}/expenses/{expenseId} {
      allow read, write: if isAuth() && isOwner(userId);
    }

    // Income
    match /users/{userId}/income/{incomeId} {
      allow read, write: if isAuth() && isOwner(userId);
    }

    // Budgets
    match /users/{userId}/budgets/{budgetId} {
      allow read, write: if isAuth() && isOwner(userId);
    }

    // Recurring expenses
    match /users/{userId}/recurring/{recurringId} {
      allow read, write: if isAuth() && isOwner(userId);
    }

    // Groups
    match /groups/{groupId} {
      allow read: if isAuth() && request.auth.uid in resource.data.memberIds;
      allow create: if isAuth();
      allow update, delete: if isAuth() && request.auth.uid == resource.data.createdBy;
    }

    // Top-level user docs
    match /{collection}/{docId} {
      allow read, write: if isAuth() && request.auth.uid == docId;
    }
  }
}
